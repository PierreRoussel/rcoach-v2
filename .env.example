# Nhost Cloud project (required)
VITE_NHOST_SUBDOMAIN=your-subdomain
VITE_NHOST_REGION=eu-central-1

# Google OAuth (Nhost Dashboard → Auth → Google + Google Cloud Console)
# Enable the Google provider in Nhost, then add these client redirect URLs in Nhost:
#   http://localhost:5173/auth/verify          (Vite dev)
#   https://<your-production-domain>/auth/verify
#   https://localhost/auth/verify            (Capacitor Android)
# In Google Cloud Console (OAuth Web client):
#   Authorized JavaScript origins → https://<subdomain>.auth.<region>.nhost.run
#   Authorized redirect URIs → OAuth callback URL shown in Nhost Google settings

# Open Food Facts
# - Web dev/preview: Vite proxies /api/open-food-facts and /api/open-food-facts-search
# - Web prod (Vercel/Netlify): same paths via rewrites in vercel.json / netlify.toml
# - Native (Capacitor): uses the Nhost function proxy when subdomain/region are set:
#   https://<subdomain>.functions.<region>.nhost.run/v1/open-food-facts?path=...
# Override only if you host a custom proxy:
# VITE_OFF_API_BASE=https://your-domain.com/api/open-food-facts
# VITE_OFF_SEARCH_API_BASE=https://your-domain.com/api/open-food-facts-search

# GraphQL Codegen only — find in Nhost Dashboard → Settings → Hasura
CODEGEN_HASURA_ADMIN_SECRET=your-admin-secret

# Optional — server-side ingest / enrich function (same secret as Hasura admin)
# NHOST_ADMIN_SECRET=your-admin-secret
# NHOST_SUBDOMAIN=your-subdomain
# NHOST_REGION=eu-central-1

# Optional override for native enrich function URL
# VITE_ENRICH_EXERCISE_FUNCTION_URL=https://your-subdomain.functions.eu-central-1.nhost.run/v1/enrich-exercise-content

# Bulk OFF catalog import (scripts/import-off-france-jsonl.mjs)
# Nhost Dashboard → Settings → Database → enable Public access → Reset password → copy connection string
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@YOUR_SUBDOMAIN.db.eu-central-1.nhost.run:5432/YOUR_SUBDOMAIN

# Alternative if the password has special characters (recommended):
# PGHOST=YOUR_SUBDOMAIN.db.eu-central-1.nhost.run
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=your-plain-password
# PGDATABASE=YOUR_SUBDOMAIN
